{
  "version": 2,
  "functions": {
    "index.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "ajaxs/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "cron/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*\\.php)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
