{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "excludeFiles": "{public/**,assets/**,vendor/**,cron/**,*.sql,*.zip,*.phar,install.php,update.php,composer.json,composer.lock}"
    }
  },
  "rewrites": [
    {
      "source": "/ajaxs/(.*)",
      "destination": "/api/index.php?ajax_file=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
